# Terraform
**/.terraform/*
.terraform.lock.hcl.tmp
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Plans / gate artifacts (always regenerated by the gate)
tfplan.binary
tfplan*.json
gate-result.json

# Local evidence / logs (kept locally, not in the repo)
.evidence/

# Secrets — never commit
*.auto.tfvars
.env
*.pem
